# Server (only used for local dev — Vercel sets PORT automatically)
PORT=3001
NODE_ENV=development

# JWT — set this to a long random string in production
JWT_SECRET=local-dev-secret-doesnt-matter

# Frontend origin for CORS (production). Local dev allows localhost:5173 and
# any *.vercel.app automatically.
FRONTEND_URL=https://voice-ai-console-frontend.vercel.app

# Supabase — REQUIRED for persistent storage.
# Get these from your Supabase project dashboard: Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...your-service-role-key...
